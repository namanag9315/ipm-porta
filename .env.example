# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# Database (preferred for production)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DB_SSL_REQUIRE=True

# Google Apps Script bridge (one of these is required for sync)
# GAS_BRIDGE_URL can return the full JSON payload when called directly.
GAS_BRIDGE_URL=https://script.google.com/macros/s/EXAMPLE/exec
# GAS_BRIDGE_BASE_URL is used with spreadsheetId/sheetId params.
GAS_BRIDGE_BASE_URL=https://script.google.com/macros/s/EXAMPLE/exec

# Optional per-sheet fallbacks (IDs or full URLs)
TIMETABLE_SHEET_ID=your_timetable_sheet_id_or_url
ATTENDANCE_SHEET_ID=your_attendance_sheet_id_or_url
MESS_MENU_SHEET_ID=your_mess_menu_sheet_id_or_url
BIRTHDAY_SHEET_ID=your_birthday_sheet_id_or_url

# Optional celery/redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
